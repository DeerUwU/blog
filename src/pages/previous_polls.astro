---
import BaseHead from '../components/BaseHead.astro';
import Cosmetic from '../components/Cosmetic.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import '../styles/text.css';


---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE}/>
		<style>
			main {
				max-width: 700px;
				height: -webkit-fill-available;
				height: 80vh;
				/* margin: 20px; */
				gap: 20px;
				display: flex;
				justify-self: center;
				justify-content: center;
				flex-direction: row;
				
			}
			#main {
				max-height: fit-content;
				display: flex;
				flex-direction: column;
				gap: 20px;

				padding-right: 10px;
			}

			#main:hover::-webkit-scrollbar-thumb {
				background-color: var(--primary);
			}

			#main > section {
				padding: 12px 20px 20px 20px;
				width: auto;
			}

			@media only screen and (max-width: 800px) {
				body {
					overflow: auto;
				}
				main {
					width: -webkit-fill-available;
					height: auto;
					flex-direction: column;
					padding: 1em;
				}
				#main {
					width: auto;
					max-width: 100%;
				}
			}


			.poll {
				margin-top: 10px;
				width: 100%;
			}


			.poll-wrapper {
				background-color:var(--background-trans); 
				display: flex;
				margin-top: 5px;
				padding: 10px;
				flex-direction: column;
				align-content: center;
				align-items: flex-start;
			}
			.radio-wrapper {

			}
		</style>
	</head>

	
	<body>
		<Cosmetic />
		<Header />
		<main>
			
			<section id="main" class="scrollable">
				<section class="poll frosted-glass anim-fadein-up-small anim-ease delay-200ms">
					<h2>&lt; Previous Polls &gt;</h2>
					<hr>
					<p>
						here are some polls ive created in the past.
					</p>
				</section>


				<section class="poll frosted-glass anim-fadein-up-small anim-ease delay-200ms">
					<h5>&lt; started: 19/02/26 &gt;</h5>
					<hr class="dashed">
					<p>
						since discord is doing its best to shoot itself in the foot, what are your favorite discord alternatives? 
						<br>
						(<a href="https://www.reddit.com/r/degoogle/comments/1r5catk/discord_alternatives/" target="_blank">list based on this post</a>)
					</p>
					<br />
					<h5>my favorite alternatives are...</h5>
					<form method="post" action="https://poll.pollcode.com/77128117">
						<div class="poll-wrapper">
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="1" id="answer454981341" style="float:left;"/>
								<label for="answer454981341" style="float:left;">Matrix</label>
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="2" id="answer771281171" style="float:left;"/>
								<label for="answer771281171" style="float:left;">Stoat (formerly Revolt)</label>
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="3" id="answer771281173" style="float:left;"/>
								<label for="answer771281173" style="float:left;">Pulse</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="4" id="answer771281174" style="float:left;"/>
								<label for="answer771281174" style="float:left;">XMPP</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="5" id="answer771281175" style="float:left;"/>
								<label for="answer771281175" style="float:left;">Fluxer</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="6" id="answer771281176" style="float:left;"/>
								<label for="answer771281176" style="float:left;">Nerimity</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="7" id="answer771281177" style="float:left;"/>
								<label for="answer771281177" style="float:left;">Root</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="8" id="answer771281178" style="float:left;"/>
								<label for="answer771281178" style="float:left;">Spacebar</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="checkbox" name="answer" value="9" id="answer771281179" style="float:left;"/>
								<label for="answer771281179" style="float:left;">Other (comment)</label>				
							</div>
							
							<div style="padding:3px;">
								<input type="submit" name="view" value=" Results " class="button snd_mod_hover snd_click_blip1"/>
							</div>
						</div>
					</form>
				</section>
				
				<section class="poll frosted-glass anim-fadein-up-small anim-ease delay-200ms">
					<h4>&lt; 26/09/25 - 22/12/25 &gt;</h4>
					<hr>
					<p>
						i have so many interests but my attention is spread too thin across all
						of them, so ill let this poll pick something for me.
					</p>
					<br />
					<h5>I should focus on...</h5>
					<form method="post" action="https://poll.pollcode.com/45498134">
						<div class="poll-wrapper">
							<div class="radio-wrapper">
								<input disabled type="radio" name="answer" value="1" id="answer454981341" style="float:left;"/>
								<label for="answer454981341" style="float:left;width:168px;">2d art</label>
							</div>
							<div class="radio-wrapper">
								<input disabled type="radio" name="answer" value="2" id="answer454981342" style="float:left;"/>
								<label for="answer454981342" style="float:left;width:168px;">3d modelling</label>
							</div>

							<div class="radio-wrapper">
								<input disabled type="radio" name="answer" value="3" id="answer454981343" style="float:left;"/>
								<label for="answer454981343" style="float:left;width:168px;">music</label>				
							</div>
							<div class="radio-wrapper">
								<input disabled type="radio" name="answer" value="4" id="answer454981344" style="float:left;"/>
								<label for="answer454981344" style="float:left;width:168px;">game dev</label>				
							</div>

							
							<div style="padding:3px;">
								<input type="submit" name="view" value=" Results " class="button snd_mod_hover snd_click_blip1"/>
							</div>
						</div>
					</form>
				</section>

			</section>

		</main>
		<Footer/>


		<!-- <script>
			particlesJS.load("particles-js", "/particles/404.json", function(){
			console.log("PARTICLES: 404.json loaded")
			});
		</script> -->
	</body>
	
</html>
